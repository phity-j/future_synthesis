---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
  title = "FUTURE SYNTHESIS | 未来予測メディア", 
  description = "AI・文明・建築・国家・資本の未来を考察する知的メディア",
  image = "/images/hero_bg.png" 
} = Astro.props;

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    
    <!-- OGP / Twitter Card -->
    <meta property="og:type" content="website">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={new URL(image, Astro.site || 'https://phity-j.github.io/future_synthesis/')}>
    <meta name="twitter:card" content="summary_large_image">
    
    <!-- Google Fonts Preload -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Noto+Sans+JP:wght@400;500;700&family=Space+Grotesk:wght@700&display=swap" rel="preload" as="style" onload="this.onload=null;this.rel='stylesheet'">
    
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
</head>
<body>
    <header class="glass-header">
        <div class="header-container">
            <a href="/future_synthesis/" class="logo">FUTURE SYNTHESIS</a>
            <nav>
                <ul class="nav-links">
                    <li><a href="/future_synthesis/#articles">最新記事</a></li>
                    <li><a href="/future_synthesis/#newsletter">ニュースレター</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <slot />

    <footer>
        <div class="footer-content">
            <h2 class="logo">FUTURE SYNTHESIS</h2>
            <p>&copy; 2026 Future Synthesis Media. Built with Astro & Pages CMS.</p>
        </div>
    </footer>

    <script>
        // Header scroll effect
        const header = document.querySelector('.glass-header') as HTMLElement;
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                header.style.background = 'rgba(3, 3, 8, 0.85)';
                header.style.borderBottom = '1px solid rgba(0, 240, 255, 0.2)';
            } else {
                header.style.background = 'rgba(3, 3, 8, 0.6)';
                header.style.borderBottom = '1px solid rgba(255, 255, 255, 0.05)';
            }
        });
        
        // Scroll fade-in observer
        const observer = new IntersectionObserver((entries, obs) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    obs.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15 });
        
        document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
    </script>
</body>
</html>
